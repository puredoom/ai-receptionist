# Copy this file to .env and fill in real values. Never commit .env.

# --- Server ---
PORT=3000
# Public URL of this server (needed by Vapi + Google OAuth). Use your Railway/Render URL,
# or an ngrok URL during local testing, e.g. https://abc123.ngrok.app
BASE_URL=http://localhost:3000
# Any long random string; protects the admin dashboard and API
ADMIN_KEY=change-me-to-a-long-random-string

# --- Vapi (voice platform, vapi.ai) ---
VAPI_API_KEY=
# Any long random string; Vapi sends it back on webhooks so we know calls are real
VAPI_WEBHOOK_SECRET=change-me-too

# --- Google Calendar OAuth (console.cloud.google.com) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Voice (optional overrides) ---
# ElevenLabs voice used via Vapi. Any multilingual-v2 voice can speak Dutch.
DEFAULT_VOICE_ID=XB0fDUnXU5powFXDhCwa
